        {
          "name": "increment_retry",
          "type": "SetVariable",
          "depends_on": [],
          "variable_name": "retries",
          "variable_value": {
            "value": "@string(add(int(variables('retries')), 1))",
            "type": "Expression"
          }
        }
      ]
    },
    "expected": {
      "name": "retry_loop",
      "task_key": "retry_loop"
    }
  },
