[
  {
    "id": "basic",
    "description": "Basic Until with retry condition",
    "input": {
      "name": "retry_loop",
      "type": "Until",
      "description": "Retry until condition met",
      "depends_on": [],
      "expression": {
        "value": "@greaterOrEquals(variables('retries'), 3)",
        "type": "Expression"
      },
      "timeout": "0.04:00:00",
